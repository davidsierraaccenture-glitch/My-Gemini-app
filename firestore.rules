rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'david.sierra.accenture@gmail.com'
      ); 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Phase 4: Entity Validation Helpers
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'description', 'price', 'categoryId', 'imageUrl', 'stock'])
        && data.keys().size() >= 6
        && data.name is string && data.name.size() <= 200
        && data.description is string && data.description.size() <= 2000
        && data.price is number && data.price >= 0
        && data.stock is int && data.stock >= 0
        && data.imageUrl is string && data.imageUrl.size() <= 1024;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'total', 'status', 'createdAt', 'items'])
        && data.keys().size() == 5
        && data.userId == request.auth.uid
        && data.total is number && data.total >= 0
        && data.status in ['pending', 'completed', 'cancelled']
        && data.createdAt == request.time
        && data.items is list && data.items.size() > 0;
    }

    // Collection Rules
    
    // Admin list - only readable by signed in users to check role, or strictly by admin
    match /admins/{adminId} {
      allow get: if isSignedIn();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && userId == request.auth.uid;
      allow create: if isVerified() && userId == request.auth.uid;
      allow update: if isVerified() && userId == request.auth.uid 
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastLogin']);
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidOrder(incoming());
      // Orders are immutable once placed, status can only be updated by admin or if pending
      allow update: if (isAdmin()) || (
        isSignedIn() && existing().userId == request.auth.uid 
        && incoming().diff(existing()).affectedKeys().hasOnly(['status'])
        && existing().status == 'pending'
        && incoming().status == 'cancelled'
      );
    }
  }
}
