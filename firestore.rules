rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Phase 4: Entity Validation Helpers
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'createdAt', 'lastLogin'])
        && data.keys().size() == 6
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() <= 100
        && data.photoURL is string && data.photoURL.size() <= 1024
        && data.createdAt == request.time
        && data.lastLogin == request.time;
    }

    function isValidChat(data) {
      return data.keys().hasAll(['userId', 'title', 'createdAt', 'updatedAt'])
        && data.keys().size() == 4
        && data.userId == request.auth.uid
        && data.title is string && data.title.size() <= 200
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['chatId', 'role', 'content', 'createdAt'])
        && data.keys().size() == 4
        && data.role in ['user', 'model']
        && data.content is string && data.content.size() <= 10000
        && data.createdAt == request.time;
    }

    // Collection Rules
    match /users/{userId} {
      allow get: if isSignedIn() && userId == request.auth.uid;
      allow create: if isVerified() && userId == request.auth.uid && isValidUser(incoming());
      allow update: if isVerified() && userId == request.auth.uid 
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastLogin'])
        && incoming().lastLogin == request.time;
    }

    match /chats/{chatId} {
      allow list: if isVerified() && resource.data.userId == request.auth.uid;
      allow get: if isVerified() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidId(chatId) && isValidChat(incoming());
      allow update: if isVerified() && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'updatedAt'])
        && incoming().updatedAt == request.time;
      allow delete: if isVerified() && existing().userId == request.auth.uid;

      match /messages/{messageId} {
        allow list, get: if isVerified() && get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
        allow create: if isVerified() && isValidId(messageId) 
          && get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid
          && incoming().chatId == chatId
          && isValidMessage(incoming());
      }
    }
  }
}
