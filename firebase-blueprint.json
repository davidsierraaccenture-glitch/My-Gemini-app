{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user profile in the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The Firebase Auth UID." },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Represents a conversation session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Represents a single message within a chat.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "role", "content", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "chats/{chatId}": {
      "schema": "Chat",
      "description": "Collection of chat sessions."
    },
    "chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Sub-collection of messages for a chat."
    }
  }
}
