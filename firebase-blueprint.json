{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user profile in the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The Firebase Auth UID." },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "An electronic item for sale.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "categoryId": { "type": "string" },
        "imageUrl": { "type": "string", "description": "Storage download URL." },
        "stock": { "type": "integer" },
        "featured": { "type": "boolean" }
      },
      "required": ["name", "price", "categoryId", "stock"]
    },
    "Category": {
      "title": "Category",
      "description": "A group of related products.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" }
      },
      "required": ["name", "slug"]
    },
    "Order": {
      "title": "Order",
      "description": "A completed purchase.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "total", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Public user profiles."
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Global product catalog."
    },
    "categories/{categoryId}": {
      "schema": "Category",
      "description": "Product category definitions."
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "User purchase history."
    }
  }
}
